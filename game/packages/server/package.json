{
  "name": "@icgame/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsx esbuild src/index.ts --bundle --platform=node --outdir=dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@icgame/bot": "workspace:*",
    "@icgame/game-engine": "workspace:*",
    "@icgame/shared": "workspace:*",
    "@koa/router": "^15.4.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "boardgame.io": "^0.50.2",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "koa": "^3.2.0",
    "koa-bodyparser": "^4.4.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "rate-limiter-flexible": "^11.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/koa": "^3.0.2",
    "@types/koa-bodyparser": "^4.3.13",
    "@types/koa__router": "^12.0.5",
    "@types/pg": "^8.20.0",
    "prisma": "^7.7.0",
    "tsx": "^4.21.0"
  }
}
