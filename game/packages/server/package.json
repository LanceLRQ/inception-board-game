{
  "name": "@icgame/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsx esbuild src/index.ts --bundle --platform=node --outdir=dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@icgame/shared": "workspace:*",
    "@icgame/game-engine": "workspace:*",
    "@icgame/bot": "workspace:*"
  }
}
