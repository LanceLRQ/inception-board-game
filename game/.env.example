# ============================================
# 盗梦都市 · 环境变量模板
# 对照：plans/design/04-system-architecture.md §4.6 私有部署
# ============================================
# 使用：
#   cp .env.example .env
#   然后按需修改下面的值（至少改 JWT_SECRET）
# ============================================

# ---------- 端口映射（宿主机 → 容器） ----------
CLIENT_PORT=80
API_PORT=3001
POSTGRES_PORT=5432
REDIS_PORT=6379

# ---------- Postgres ----------
POSTGRES_DB=icgame
POSTGRES_USER=icgame
# 生产环境务必修改为高强度密码
POSTGRES_PASSWORD=icgame_dev

# ---------- API 服务 ----------
# JWT 签名密钥，生产环境务必改为 32+ 字节的随机串
# 生成建议：openssl rand -base64 48
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
JWT_EXPIRES_IN=30d

# CORS 白名单：生产建议填域名（例 https://ico.example.com），开发用 *
WS_CORS_ORIGIN=*
WS_PATH=/ws

# 日志级别：trace|debug|info|warn|error|fatal
LOG_LEVEL=info

# ---------- 前端构建参数 ----------
# 浏览器访问 API 的前缀（通过 nginx 反代走 /api）
VITE_API_BASE=/api
# 浏览器 WebSocket 连接 URL（通过 nginx 反代走 /ws）
VITE_WS_URL=/ws

# ---------- 本地开发（非 docker-compose 路径时使用） ----------
# DATABASE_URL=postgresql://icgame:icgame_dev@localhost:5432/icgame
# REDIS_URL=redis://localhost:6379
# NODE_ENV=development
# PORT=3001
